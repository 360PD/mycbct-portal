"""
Backblaze B2 storage, through its S3-compatible API (so we use boto3).

Download the original scan; upload the generated preview frames + manifest.
The worker only ever READS the original and WRITES new files beside it.
"""

import os

import boto3
from botocore.config import Config

import config

_s3 = boto3.session.Session().client(
    "s3",
    endpoint_url=config.B2_ENDPOINT,
    aws_access_key_id=config.B2_KEY_ID,
    aws_secret_access_key=config.B2_APP_KEY,
    config=Config(signature_version="s3v4"),
)


def download(key, local_path):
    """Download one object from the bucket to a local file."""
    os.makedirs(os.path.dirname(local_path), exist_ok=True)
    _s3.download_file(config.B2_BUCKET, key, local_path)


def upload_file(local_path, key, content_type):
    """Upload one local file to the bucket under `key`."""
    _s3.upload_file(
        local_path,
        config.B2_BUCKET,
        key,
        ExtraArgs={"ContentType": content_type},
    )

"""
The worker loop.

Watches the database for a scan marked 'pending', processes it into preview
frames, uploads them next to the original in Backblaze, and flips the scan to
'ready'. If anything goes wrong it retries a couple of times, then marks the
scan 'failed' (the viewer falls back to Download).

Run with:  python worker.py
"""

import os
import shutil
import tempfile
import time
import traceback

import config
import db
import dicom_to_frames as d2f
import storage


def _preview_key(scan_id, relative):
    """Where a preview file lives in the bucket: previews/<scan_id>/<relative>."""
    return f"{config.PREVIEW_PREFIX}/{scan_id}/{relative}"


def process(scan_id, storage_key):
    """Build and upload previews for one scan."""
    work_dir = tempfile.mkdtemp(prefix=f"scan_{scan_id}_")
    try:
        zip_path = os.path.join(work_dir, "original.zip")
        print(f"[{scan_id}] downloading original: {storage_key}")
        storage.download(storage_key, zip_path)

        print(f"[{scan_id}] building previews")
        out_dir, _manifest, total = d2f.build_previews(zip_path, work_dir, scan_id)

        print(f"[{scan_id}] uploading {total} frames + manifest")
        for root, _, names in os.walk(out_dir):
            for name in names:
                local = os.path.join(root, name)
                relative = os.path.relpath(local, out_dir).replace(os.sep, "/")
                content_type = "application/json" if name.endswith(".json") else "image/jpeg"
                storage.upload_file(local, _preview_key(scan_id, relative), content_type)

        manifest_key = _preview_key(scan_id, "manifest.json")
        db.mark_ready(scan_id, manifest_key, total)
        print(f"[{scan_id}] done — preview ready ({total} frames)")
    finally:
        shutil.rmtree(work_dir, ignore_errors=True)


def run_once():
    """Process one scan if any is waiting. Returns True if it did work."""
    row = db.claim_next_scan()
    if not row:
        return False

    scan_id, storage_key, attempts = row
    try:
        process(scan_id, storage_key)
    except Exception as exc:
        error = f"{exc.__class__.__name__}: {exc}"[:1000]
        traceback.print_exc()
        if attempts >= config.MAX_ATTEMPTS:
            db.mark_failed(scan_id, error)
            print(f"[{scan_id}] FAILED after {attempts} attempt(s)")
        else:
            db.mark_retry(scan_id, error)
            print(f"[{scan_id}] will retry later (attempt {attempts})")
    return True


def main():
    print("Preview worker started. Watching for pending scans…")
    while True:
        try:
            did_work = run_once()
        except Exception:
            # Never let the loop die — log and keep watching.
            traceback.print_exc()
            did_work = False
        if not did_work:
            time.sleep(config.POLL_SECONDS)


if __name__ == "__main__":
    main()
